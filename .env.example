# Client (Vite) — set VITE_AI_USE_PROXY=true for secure server-side AI calls
VITE_AI_USE_PROXY=true
VITE_AI_PROVIDER=xai

# Game server the client connects to (single + multiplayer). Use the host's
# LAN/public IP + port to play with friends; VITE_MULTIPLAYER=0 forces offline.
VITE_GAME_SERVER_URL=ws://localhost:8080
VITE_MULTIPLAYER=1

# Direct client keys (dev only — do NOT use in production builds)
# VITE_OPENAI_API_KEY=sk-...
# VITE_ANTHROPIC_API_KEY=sk-ant-...
# VITE_XAI_API_KEY=xai-...
# VITE_XAI_MODEL=grok-4.3   # optional: override the direct-call model (dev only)

# Game server (server/gameServer.ts) — runs independently of the game
GAME_SERVER_PORT=8080
AI_NPCS=0          # 1 to inject AI NPCs by default (also toggleable from the dashboard)
AI_NPC_COUNT=2

# Server (server/index.ts) — keys live here in production
PORT=3847
VITE_PROXY_PORT=3847
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
XAI_API_KEY=xai-...
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
XAI_MODEL=grok-4.3
